{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							[":PACKAGE:", "!@actual_src/**", "!@steamclient_types/**"],
							":BLANK_LINE:",
							["@actual_src/**", "!@steamclient_types/**"],
							":BLANK_LINE:",
							":PATH:"
						]
					}
				}
			}
		}
	},
	"files": {
		"maxSize": 123123123123
	},
	"linter": {
		"enabled": false
	}
}
